---
interface Props {
  src?: string | null;
  alt: string;
  fallbackSrc: string;
  class?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  fetchpriority?: "high" | "low" | "auto";
  style?: string;
  width?: number | string;
  height?: number | string;
}

const {
  src,
  alt,
  fallbackSrc,
  class: className,
  loading = "lazy",
  decoding = "async",
  fetchpriority,
  style,
  width,
  height,
} = Astro.props as Props;

const safeSrc = src && src.trim().length > 0 ? src : fallbackSrc;
const onError = `if(this.src!==window.location.origin+'${fallbackSrc}'&&this.getAttribute('src')!=='${fallbackSrc}'){this.src='${fallbackSrc}';}`;
---

<img
  src={safeSrc}
  alt={alt}
  class={className}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchpriority}
  style={style}
  width={width}
  height={height}
  onerror={onError}
/>
