---
import PixelButton from "@/components/PixelButton.astro";
import PixelCard from "@/components/PixelCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteContent, images } from "@/data/site";
import { ICONS } from "@/lib/icons";

const { dashboard } = siteContent;
---

<BaseLayout title="Biblioteca" currentPath="/" showFab={true}>
  <div class="space-y-8">
    <section class="relative h-[450px] overflow-hidden bg-surface-container-lowest pixel-border">
      <div
        class="absolute inset-0 bg-cover bg-center opacity-60"
        style={`background-image: url(${images.libraryHero});`}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent" />
      <div class="absolute inset-0 opacity-40 pointer-events-none">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(255,185,97,0.28)_0,transparent_18%),radial-gradient(circle_at_70%_30%,rgba(173,208,168,0.22)_0,transparent_16%),radial-gradient(circle_at_50%_80%,rgba(231,189,177,0.2)_0,transparent_14%)]" />
      </div>

      <div class="absolute bottom-12 left-8 max-w-2xl">
        <div class="inline-block bg-secondary-container px-3 py-1 mb-4 border-l-4 border-primary">
          <span class="text-primary-fixed font-headline font-bold text-xs uppercase tracking-[0.2em]">
            {dashboard.hero.badge}
          </span>
        </div>
        <h1 class="text-5xl md:text-7xl font-headline font-black text-on-surface uppercase tracking-tighter leading-none mb-4 drop-shadow-[4px_4px_0px_#181210]">
          {dashboard.hero.titleStart} <span class="text-primary">{dashboard.hero.titleAccent}</span>
        </h1>
        <p class="text-on-surface-variant font-body text-lg max-w-md bg-surface/80 backdrop-blur-sm p-4 border-2 border-outline-variant/30">
          {dashboard.hero.description}
        </p>
        <div class="flex flex-wrap gap-4 mt-6">
          <PixelButton href={dashboard.hero.primaryHref} size="lg" icon="BookOpen">{dashboard.hero.primaryCta}</PixelButton>
          <PixelButton href={dashboard.hero.secondaryHref} variant="tertiary" size="lg">{dashboard.hero.secondaryCta}</PixelButton>
        </div>
      </div>
    </section>

    <section id="espacios">
      <div class="flex items-center justify-between mb-8 gap-4">
        <h2 class="text-3xl font-headline font-black text-tertiary uppercase tracking-tighter flex items-center gap-3">
          <span class="w-8 h-8 bg-tertiary-container border-2 border-tertiary flex items-center justify-center">
            <ICONS.Castle className="text-tertiary" size={16} />
          </span>
          {dashboard.spaces.title}
        </h2>
        <div class="h-1 flex-1 mx-8 dither-bg opacity-20 hidden md:block"></div>
        <a
          href={dashboard.spaces.linkHref}
          class="text-primary font-headline font-bold uppercase text-xs tracking-widest flex items-center gap-1 hover:underline"
        >
          {dashboard.spaces.linkLabel} <ICONS.ArrowUpRight className="inline" size={14} />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <a
          href={dashboard.spaces.sharedLibrary.href}
          class="md:col-span-8 bg-surface-container-high border-4 border-surface-container-highest p-1 group overflow-hidden text-left"
        >
          <div class="relative h-72 md:h-[28rem] bg-surface-dim overflow-hidden">
            <img
              src={images.silentWing}
              class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
              style="object-position: center 46%;"
              alt={dashboard.spaces.sharedLibrary.alt}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
            <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(24,18,16,0.92)_0%,rgba(24,18,16,0.86)_28%,rgba(24,18,16,0.38)_56%,rgba(24,18,16,0.18)_100%)]"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/72 via-transparent to-black/10"></div>
            <div class="absolute top-4 left-4 bg-tertiary px-3 py-1 font-headline font-bold text-on-tertiary text-xs uppercase tracking-tighter">
              {dashboard.spaces.sharedLibrary.badge}
            </div>
            <div class="absolute inset-0 flex flex-col justify-end p-6 md:max-w-[48%]">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                <span class="text-primary text-xs font-bold uppercase tracking-widest">{dashboard.spaces.sharedLibrary.status}</span>
              </div>
              <h3 class="text-2xl font-headline font-black text-white uppercase tracking-tighter">
                {dashboard.spaces.sharedLibrary.title}
              </h3>
              <p class="text-on-surface-variant text-sm font-body mt-2 max-w-lg">
                {dashboard.spaces.sharedLibrary.description}
              </p>
            </div>
          </div>
        </a>

        <a
          href={dashboard.spaces.garden.href}
          class="md:col-span-4 bg-surface-container-high border-4 border-surface-container-highest p-1 group overflow-hidden text-left"
        >
          <div class="relative h-full min-h-[250px] bg-surface-dim overflow-hidden">
            <img
              src={images.gardenTerrace}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              alt={dashboard.spaces.garden.alt}
              loading="lazy"
              decoding="async"
            />
            <div class="absolute top-4 left-4 bg-primary px-3 py-1 font-headline font-bold text-on-primary text-xs uppercase tracking-tighter">
              {dashboard.spaces.garden.badge}
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex flex-col justify-end p-6">
              <h3 class="text-xl font-headline font-black text-white uppercase tracking-tighter">{dashboard.spaces.garden.title}</h3>
              <p class="text-on-surface-variant text-xs font-body mt-2">{dashboard.spaces.garden.description}</p>
            </div>
          </div>
        </a>

        {dashboard.spaces.secondaryLinks.map((item) => {
          const Icon = ICONS[item.icon];
          return (
            <div class="md:col-span-3">
              <PixelCard variant="low" class="h-full flex flex-col gap-4">
                <div class="w-12 h-12 bg-surface-container-highest flex items-center justify-center border-b-4 border-secondary-container">
                  <Icon className={item.icon === "History" ? "text-tertiary" : "text-primary"} size={24} />
                </div>
                <div>
                  <h4 class="font-headline font-bold uppercase tracking-widest text-on-surface text-sm">{item.title}</h4>
                  <p class="text-xs text-outline mt-1 font-body">{item.description}</p>
                </div>
                <PixelButton href={item.href} variant="ghost" fullWidth={true} class={`mt-auto border-2 ${item.accentClass}`}>
                  {item.cta}
                </PixelButton>
              </PixelCard>
            </div>
          );
        })}

        <div class="md:col-span-6">
          <PixelCard variant="default" class="relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-24 h-24 dither-bg opacity-10"></div>
            <div class="flex items-start justify-between gap-6">
              <div class="max-w-[60%]">
                <h4 class="font-headline font-black uppercase text-2xl tracking-tighter text-secondary">{dashboard.progressPanel.title}</h4>
                <p class="text-sm text-on-surface-variant mt-2 font-body">{dashboard.progressPanel.description}</p>
                <div class="mt-6">
                  <div class="w-full h-4 bg-tertiary-container relative">
                    <div class="absolute inset-y-0 left-0 bg-primary w-[65%] flex items-center justify-end pr-1">
                      <ICONS.Flame className="text-on-primary animate-pulse" size={10} />
                    </div>
                  </div>
                  <div class="flex justify-between mt-1">
                    <span class="text-[10px] font-headline font-bold uppercase text-outline">{dashboard.progressPanel.progressLabel}</span>
                    <span class="text-[10px] font-headline font-bold uppercase text-primary">{dashboard.progressPanel.progressValue}</span>
                  </div>
                </div>
              </div>
              <div class="w-24 h-24 bg-surface-container-highest border-4 border-outline-variant flex items-center justify-center p-2 shrink-0">
                <img src={images.questBadge} alt={dashboard.progressPanel.alt} class="w-full h-full" loading="lazy" decoding="async" />
              </div>
            </div>
          </PixelCard>
        </div>
      </div>
    </section>

    <section id="pulso-personal">
      <div class="bg-surface-container-highest border-t-8 border-primary-container p-8 relative pixel-border">
        <div class="flex flex-col md:flex-row gap-8 items-center">
          <div class="w-48 h-48 bg-surface border-4 border-surface-container-highest pixel-border-inset flex items-center justify-center relative group">
            <img src={images.ancientBook} class="w-32 h-32 object-contain" alt={dashboard.currentFocus.alt} loading="lazy" decoding="async" />
            <div class="absolute -bottom-4 bg-primary text-on-primary font-headline font-bold text-[10px] px-3 py-1 uppercase tracking-widest bezel-button">
              {dashboard.currentFocus.level}
            </div>
          </div>
          <div class="flex-1 text-center md:text-left">
            <h2 class="text-3xl font-headline font-black text-tertiary uppercase tracking-tighter mb-3">{dashboard.currentFocus.title}</h2>
            <h3 class="text-4xl font-headline font-black text-on-surface uppercase tracking-tighter mb-2">{dashboard.currentFocus.bookTitle}</h3>
            <p class="text-outline font-headline font-bold text-sm tracking-widest uppercase mb-4">{dashboard.currentFocus.progress}</p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
              {dashboard.currentFocus.stats.map((stat) => (
                <div class:list={["bg-surface-container-low p-4 border-b-4", stat.color]}>
                  <p class="text-[10px] font-headline font-bold text-outline uppercase tracking-widest">{stat.label}</p>
                  <p class:list={["text-2xl font-headline font-black", stat.textColor]}>{stat.value}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
