---
import PixelButton from "@/components/PixelButton.astro";
import PixelCard from "@/components/PixelCard.astro";
import FallbackImage from "@/components/FallbackImage.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteContent, images } from "@/data/site";
import { ICONS } from "@/lib/icons";
import { CurrentPulsePanel } from "@/islands/sanctuary/CurrentPulsePanel";
import { HubSocialSpaces } from "@/islands/sanctuary/HubSocialSpaces";
import { db } from "@/lib/server/db";

const { dashboard } = siteContent;

const WEEKLY_GOAL_SESSIONS = 20;

const weeklyCompletedSessions = Astro.locals.user
  ? ((
      db
        .prepare(
          `SELECT COUNT(*) as total
           FROM pomodoro_sessions
           WHERE user_id = ?
             AND DATE(completed_at) >= DATE('now', '-6 days')`,
        )
        .get(Astro.locals.user.id) as { total: number }
    ).total ?? 0)
  : Math.round((65 / 100) * WEEKLY_GOAL_SESSIONS);

const weeklyProgressPercent = Math.max(
  0,
  Math.min(
    100,
    Math.round((weeklyCompletedSessions / WEEKLY_GOAL_SESSIONS) * 100),
  ),
);

const weeklyProgressValue = `${weeklyProgressPercent}% completado`;
---

<BaseLayout title="Biblioteca" currentPath="/" showFab={true}>
  <div class="space-y-8">
    <section
      class="relative h-[450px] overflow-hidden bg-surface-container-lowest pixel-border"
    >
      <FallbackImage
        src={images.libraryHero}
        fallbackSrc="/site/placeholder-landscape.svg"
        alt={dashboard.hero.titleStart + " " + dashboard.hero.titleAccent}
        class="absolute inset-0 h-full w-full object-cover opacity-60"
        loading="eager"
        decoding="async"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent"
      >
      </div>
      <div class="absolute inset-0 opacity-40 pointer-events-none">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(255,185,97,0.28)_0,transparent_18%),radial-gradient(circle_at_70%_30%,rgba(173,208,168,0.22)_0,transparent_16%),radial-gradient(circle_at_50%_80%,rgba(231,189,177,0.2)_0,transparent_14%)]"
        >
        </div>
      </div>

      <div class="absolute bottom-12 left-8 max-w-2xl">
        <div
          class="inline-block bg-secondary-container px-3 py-1 mb-4 border-l-4 border-primary"
        >
          <span
            class="text-primary-fixed font-headline font-bold text-xs uppercase tracking-[0.2em]"
          >
            {dashboard.hero.badge}
          </span>
        </div>
        <h1
          class="text-5xl md:text-7xl font-headline font-black text-on-surface uppercase tracking-tighter leading-none mb-4 drop-shadow-[4px_4px_0px_#181210]"
        >
          {dashboard.hero.titleStart}
          <span class="text-primary">{dashboard.hero.titleAccent}</span>
        </h1>
        <p
          class="text-on-surface-variant font-body text-lg max-w-md bg-surface/80 backdrop-blur-sm p-4 border-2 border-outline-variant/30"
        >
          {dashboard.hero.description}
        </p>
        <div class="flex flex-wrap gap-4 mt-6">
          <PixelButton
            href={dashboard.hero.primaryHref}
            size="lg"
            icon="BookOpen">{dashboard.hero.primaryCta}</PixelButton
          >
          <PixelButton
            href={dashboard.hero.secondaryHref}
            variant="tertiary"
            size="lg">{dashboard.hero.secondaryCta}</PixelButton
          >
        </div>
      </div>
    </section>

    <section id="espacios">
      <div class="flex items-center justify-between mb-8 gap-4">
        <h2
          class="text-3xl font-headline font-black text-tertiary uppercase tracking-tighter flex items-center gap-3"
        >
          <span
            class="w-8 h-8 bg-tertiary-container border-2 border-tertiary flex items-center justify-center"
          >
            <ICONS.Castle className="text-tertiary" size={16} />
          </span>
          {dashboard.spaces.title}
        </h2>
        <div class="h-1 flex-1 mx-8 dither-bg opacity-20 hidden md:block"></div>
        <a
          href={dashboard.spaces.linkHref}
          class="text-primary font-headline font-bold uppercase text-xs tracking-widest flex items-center gap-1 hover:underline"
        >
          {dashboard.spaces.linkLabel}
          <ICONS.ArrowUpRight className="inline" size={14} />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <HubSocialSpaces client:only="react" />

        {
          dashboard.spaces.secondaryLinks.map((item) => {
            const Icon = ICONS[item.icon];
            return (
              <div class="md:col-span-6 lg:col-span-4">
                <PixelCard variant="low" class="h-full flex flex-col">
                  <div class="flex h-full flex-col gap-6">
                    <div class="w-12 h-12 bg-surface-container-highest flex items-center justify-center border-b-4 border-secondary-container">
                      <Icon
                        className={
                          item.icon === "History"
                            ? "text-tertiary"
                            : "text-primary"
                        }
                        size={24}
                      />
                    </div>
                    <div class="space-y-3">
                      <h4 class="font-headline font-bold uppercase tracking-widest text-on-surface text-sm">
                        {item.title}
                      </h4>
                      <p class="text-xs text-outline font-body leading-relaxed">
                        {item.description}
                      </p>
                    </div>
                    <PixelButton
                      href={item.href}
                      variant="ghost"
                      fullWidth={true}
                      class={`mt-auto border-2 ${item.accentClass}`}
                    >
                      {item.cta}
                    </PixelButton>
                  </div>
                </PixelCard>
              </div>
            );
          })
        }

        <div class="md:col-span-6 lg:col-span-4">
          <PixelCard
            variant="default"
            class="relative h-full overflow-hidden group"
          >
            <div class="absolute top-0 right-0 w-24 h-24 dither-bg opacity-10">
            </div>
            <div class="flex h-full flex-col gap-6">
              <div class="flex items-start justify-between gap-4">
                <div class="flex flex-1 flex-col pt-3">
                  <h4
                    class="font-headline text-xl font-black uppercase tracking-tighter text-secondary xl:text-2xl"
                  >
                    {dashboard.progressPanel.title}
                  </h4>
                  <p
                    class="mt-3 text-sm leading-relaxed text-on-surface-variant font-body"
                  >
                    {dashboard.progressPanel.description}
                  </p>
                </div>
                <div
                  class="h-20 w-20 shrink-0 bg-surface-container-highest border-4 border-outline-variant flex items-center justify-center p-2 xl:h-24 xl:w-24"
                >
                  <FallbackImage
                    src={images.questBadge}
                    fallbackSrc="/site/placeholder-avatar.svg"
                    alt={dashboard.progressPanel.alt}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>
              <div class="mt-auto pt-2">
                <div class="w-full h-4 bg-tertiary-container relative">
                  <div
                    class="absolute inset-y-0 left-0 bg-primary flex items-center justify-end pr-1 transition-all"
                    style={`width: ${weeklyProgressPercent}%`}
                    aria-label={`Progreso semanal: ${weeklyProgressPercent}%`}
                  >
                    <ICONS.Flame
                      className="text-on-primary animate-pulse"
                      size={10}
                    />
                  </div>
                </div>
                <div class="flex justify-between mt-1">
                  <span
                    class="text-[10px] font-headline font-bold uppercase text-outline"
                    >{dashboard.progressPanel.progressLabel}</span
                  >
                  <span
                    class="text-[10px] font-headline font-bold uppercase text-primary"
                    >{weeklyProgressValue}</span
                  >
                </div>
              </div>
            </div>
          </PixelCard>
        </div>
      </div>
    </section>

    <section id="pulso-personal">
      <CurrentPulsePanel client:only="react" />
    </section>
  </div>
</BaseLayout>
