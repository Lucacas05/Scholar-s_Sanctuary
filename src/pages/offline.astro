---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Sin conexión" currentPath="/offline" showFab={false}>
  <section class="mx-auto max-w-4xl space-y-6">
    <div
      class="relative overflow-hidden bg-surface-container-low pixel-border p-8"
    >
      <div class="absolute inset-0 dither-bg opacity-[0.12]"></div>
      <div class="absolute top-0 right-0 h-48 w-48 bg-primary/10 blur-3xl">
      </div>
      <div class="relative">
        <p
          class="font-headline text-[10px] font-bold uppercase tracking-[0.25em] text-outline"
        >
          Modo offline
        </p>
        <h1
          class="mt-3 font-headline text-4xl font-black uppercase tracking-tight text-on-surface md:text-5xl"
        >
          El santuario sigue en pie sin red
        </h1>
        <p
          class="mt-4 max-w-2xl text-sm leading-relaxed text-on-surface-variant"
        >
          Lumina ha guardado la carcasa principal para que puedas volver a abrir
          la biblioteca aunque la conexión se caiga. Las acciones que dependan
          del servidor, como sincronizar progreso o cargar amistades, volverán
          cuando recuperes internet.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/"
            class="inline-flex items-center justify-center border-b-[3px] border-on-primary-fixed-variant bg-primary px-5 py-3 font-headline text-xs font-bold uppercase tracking-widest text-on-primary"
          >
            Volver al inicio
          </a>
          <a
            href="/cronicas"
            class="inline-flex items-center justify-center border-2 border-outline-variant bg-surface-container-high px-5 py-3 font-headline text-xs font-bold uppercase tracking-widest text-on-surface"
          >
            Abrir crónicas guardadas
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
