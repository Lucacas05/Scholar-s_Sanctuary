---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PixelButton from "@/components/PixelButton.astro";
import PixelCard from "@/components/PixelCard.astro";
import { images, siteContent } from "@/data/site";
import { ICONS } from "@/lib/icons";

const sharedLibrary = siteContent.dashboard.spaces.sharedLibrary;
---

<BaseLayout title="Biblioteca compartida" currentPath="/estudio">
  <div class="max-w-6xl mx-auto space-y-8">
    <section class="relative h-[420px] overflow-hidden bg-surface-container-lowest pixel-border">
      <div
        class="absolute inset-0 bg-cover bg-center opacity-60"
        style={`background-image: url(${images.libraryHero});`}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/20 to-transparent" />
      <div class="absolute inset-0 opacity-35 pointer-events-none">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_24%,rgba(255,185,97,0.22)_0,transparent_20%),radial-gradient(circle_at_72%_18%,rgba(173,208,168,0.18)_0,transparent_16%),radial-gradient(circle_at_58%_78%,rgba(231,189,177,0.18)_0,transparent_15%)]" />
      </div>

      <div class="absolute bottom-10 left-8 max-w-3xl">
        <div class="inline-block bg-tertiary px-3 py-1 mb-4 border-l-4 border-primary">
          <span class="text-on-tertiary font-headline font-bold text-xs uppercase tracking-[0.2em]">
            {sharedLibrary.badge}
          </span>
        </div>
        <h1 class="text-5xl md:text-6xl font-headline font-black text-on-surface uppercase tracking-tighter leading-none mb-4 drop-shadow-[4px_4px_0px_#181210]">
          {sharedLibrary.title}
        </h1>
        <p class="text-on-surface-variant font-body text-lg max-w-2xl bg-surface/80 backdrop-blur-sm p-4 border-2 border-outline-variant/30">
          {sharedLibrary.description} Esta página fija el destino del espacio social sin prometer todavía presencia en tiempo real.
        </p>
        <div class="flex flex-wrap gap-4 mt-6">
          <PixelButton href="/" icon="Castle">Volver al hub</PixelButton>
          <PixelButton href="/estudio" variant="tertiary">Ir al santuario silencioso</PixelButton>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <PixelCard variant="low" title="Pomodoro compartido" subtitle="Núcleo de la sala">
        <p class="text-sm text-on-surface-variant leading-relaxed">
          Aquí acabará viviendo la versión social del estudio: foco sincronizado, mesas activas y el estado de cada amigo entrando y saliendo del ritmo.
        </p>
      </PixelCard>

      <PixelCard variant="low" title="Presencia visible" subtitle="Avatar y estado">
        <p class="text-sm text-on-surface-variant leading-relaxed">
          Los personajes 2D/2.5D de tus amigos aparecerán en esta biblioteca con estados claros como estudiando, descansando o ausente.
        </p>
      </PixelCard>

      <PixelCard variant="low" title="Sala de grupo" subtitle="No portada">
        <p class="text-sm text-on-surface-variant leading-relaxed">
          El hub solo orienta. Esta página será la que concentre el estudio con amigos para que la portada no tenga que cargar presencia social en vivo.
        </p>
      </PixelCard>
    </section>

    <section class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      <div class="lg:col-span-7">
        <PixelCard variant="default" class="h-full">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-secondary-container border-2 border-secondary flex items-center justify-center">
              <ICONS.Users className="text-secondary" size={24} />
            </div>
            <div>
              <h2 class="font-headline font-black text-2xl uppercase tracking-tighter text-secondary">Qué se implementará aquí</h2>
              <p class="text-sm text-on-surface-variant mt-2">
                Esta sala queda definida para la siguiente fase del producto, cuando entremos en avatares, amigos y estados compartidos.
              </p>
            </div>
          </div>
          <ul class="space-y-3 text-sm text-on-surface-variant">
            <li>Mesas o pasillos con avatares pixel art representando a los amigos conectados.</li>
            <li>Bocadillos automáticos mientras alguien esté en foco y mensajes cortos visibles en descanso.</li>
            <li>Presencia conectada al Pomodoro para que estudiar y descansar cambien el estado del personaje.</li>
            <li>Entrada por invitación o por lista de amistades cuando exista backend real.</li>
          </ul>
        </PixelCard>
      </div>

      <div class="lg:col-span-5">
        <PixelCard variant="highest" class="h-full">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-primary-container border-2 border-primary flex items-center justify-center">
              <ICONS.BookText className="text-primary" size={24} />
            </div>
            <div>
              <h2 class="font-headline font-black text-2xl uppercase tracking-tighter text-primary">Fase actual</h2>
              <p class="text-sm text-on-surface-variant mt-2">
                El espacio ya existe a nivel de navegación y lenguaje de producto, pero no lo hemos convertido aún en una escena social viva.
              </p>
            </div>
          </div>
          <div class="bg-surface-container-low p-4 border-l-4 border-tertiary">
            <p class="font-headline font-bold text-xs uppercase tracking-widest text-outline">Se mantiene fuera de esta fase</p>
            <p class="text-sm text-on-surface-variant mt-2">
              Amigos reales, sockets, movimiento de personajes y mensajes visibles entre usuarios.
            </p>
          </div>
        </PixelCard>
      </div>
    </section>
  </div>
</BaseLayout>
