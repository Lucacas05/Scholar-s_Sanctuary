---
import "@/index.css";
import PixelButton from "@/components/PixelButton.astro";
import Sidebar from "@/components/Sidebar.astro";
import { images, siteContent } from "@/data/site";
import { IdentityBadge } from "@/islands/sanctuary/IdentityBadge";
import { PwaBridge } from "@/islands/PwaBridge";
import { PlannerReminderBridge } from "@/islands/sanctuary/PlannerReminderBridge";
import AppFooter from "@/components/AppFooter.astro";
import { readAppConfig } from "@/lib/server/app-config";
import { readCustomWardrobeCatalog } from "@/lib/server/custom-wardrobe";
import {
  getDefaultWardrobeConfig,
  normalizeWardrobeConfig,
} from "@/lib/sanctuary/wardrobe";

interface Props {
  title: string;
  currentPath: string;
  showFab?: boolean;
  description?: string;
  image?: string;
}

const {
  title,
  currentPath,
  showFab = false,
  description,
  image,
} = Astro.props as Props;
const pageTitle = `${title} | ${siteContent.brand}`;
const pageDescription = description ?? siteContent.meta.description;
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url.origin,
);
const pageImageURL = new URL(
  image ?? images.libraryHero,
  Astro.site ?? Astro.url.origin,
);
const topItems = siteContent.navigation.topItems;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
const oauthAvailable = Boolean(
  import.meta.env.GITHUB_CLIENT_ID &&
  import.meta.env.GITHUB_CLIENT_SECRET &&
  import.meta.env.SITE_URL,
);
const customWardrobeCatalog = readCustomWardrobeCatalog();
const storedWardrobeConfig = readAppConfig("wardrobe-config");
const wardrobeConfig =
  storedWardrobeConfig?.value != null
    ? normalizeWardrobeConfig(storedWardrobeConfig.value)
    : getDefaultWardrobeConfig();
const bootstrapPayload = Astro.locals.user
  ? {
      user: {
        id: Astro.locals.user.id,
        displayName: Astro.locals.user.displayName,
        username: Astro.locals.user.username,
      },
      onboardingCompleted: Astro.locals.onboardingCompleted,
      onboardingGoal: Astro.locals.userState?.onboardingGoal ?? "",
      preferredStartPath:
        Astro.locals.userState?.preferredStartPath ?? "/biblioteca-compartida",
    }
  : null;
const serializeInlineData = (value: unknown) =>
  JSON.stringify(value).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteContent.meta.siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={pageImageURL.href} />
    <meta property="og:image:alt" content={pageDescription} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImageURL.href} />
    <meta name="theme-color" content="#181210" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Lumina" />

    <link
      rel="preload"
      as="image"
      type="image/webp"
      href={images.libraryHero}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
  </head>
  <body class="min-h-screen bg-surface flex flex-col md:flex-row">
    <Sidebar currentPath={currentPath} />

    <div class="flex-1 flex flex-col md:ml-64">
      <header
        class="bg-surface border-b-4 border-surface-container-highest flex justify-between items-center px-6 py-4 sticky top-0 z-40 shadow-[4px_4px_0px_0px_rgba(0,0,0,0.2)]"
      >
        <div class="flex items-center gap-4">
          <span
            class="text-2xl font-bold text-tertiary px-2 border-2 border-tertiary/70 font-headline uppercase tracking-tighter"
          >
            {siteContent.brand}
          </span>
        </div>
        <div class="flex items-center gap-6">
          <nav
            class="hidden lg:flex items-center gap-8 font-headline uppercase tracking-tighter text-sm font-bold"
          >
            {
              topItems.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    "pb-1 transition-all",
                    isActive(item.href)
                      ? "text-primary border-b-4 border-primary"
                      : "text-on-surface-variant hover:text-primary",
                  ]}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <div class="min-h-[40px]">
            <IdentityBadge
              client:idle
              initialUser={Astro.locals.user ?? null}
              oauthAvailable={oauthAvailable}
            />
          </div>
        </div>
      </header>

      <main class="flex-1 px-4 pb-8 pt-8 md:px-8 md:pb-10 md:pt-12 xl:pt-14">
        <slot />
      </main>

      <AppFooter />
    </div>

    {
      (
        <script
          id="lumina-wardrobe-config"
          type="application/json"
          set:html={serializeInlineData(wardrobeConfig)}
        />
      )
    }
    {
      (
        <script
          id="lumina-custom-wardrobe-catalog"
          type="application/json"
          set:html={serializeInlineData(customWardrobeCatalog)}
        />
      )
    }
    {
      bootstrapPayload && (
        <script
          id="lumina-bootstrap"
          type="application/json"
          set:html={serializeInlineData(bootstrapPayload)}
        />
      )
    }
    <PwaBridge client:idle />
    <PlannerReminderBridge client:idle />

    {
      showFab && (
        <div class="fixed right-6 bottom-20 md:bottom-8 z-40">
          <PixelButton
            href="/estudio"
            icon="Plus"
            ariaLabel="Comenzar una sesión de pomodoro"
            class="w-16 h-16 rounded-none p-0 text-on-primary bezel-button shadow-2xl"
          />
        </div>
      )
    }
  </body>
</html>
